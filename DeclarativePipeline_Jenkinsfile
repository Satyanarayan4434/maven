pipeline
{
    agent any
    environment
    {
        QA_USER     = 'ubuntu'
        QA_HOST     = credentials('qa-host')
        PROD_USER   = 'ubuntu'
        PROD_HOST   = credentials('prod-host')
        DEPLOY_PATH = '/var/lib/tomcat8/webapps'
    }
    stages
    {
        stage('ContDownload')
        {
            steps
            {
                git 'https://github.com/sunildevops77/maven.git'
            }
        }
        stage('ContBuild')
        {
            steps
            {
                sh 'mvn package'
            }
        }
        stage('ContDeployment')
        {
            steps
            {
                sh "scp ${env.WORKSPACE}/webapp/target/webapp.war ${QA_USER}@${QA_HOST}:${DEPLOY_PATH}/qaenv.war"
            }
        }
        stage('ContTesting')
        {
            steps
            {
                git 'https://github.com/sunildevops77/maven.git'
                sh "java -jar ${env.WORKSPACE}/testing.jar"
            }
        }
    }
    post
    {
        success
        {
            input message: 'Waiting for approval from DM', submitter: 'Srinivas'
            sh "scp ${env.WORKSPACE}/webapp/target/webapp.war ${PROD_USER}@${PROD_HOST}:${DEPLOY_PATH}/prodenv.war"
        }
        failure
        {
            mail bcc: '', body: 'Build has failed. Please check Jenkins for details.', cc: '', from: '', replyTo: '', subject: 'Build failed', to: 'gandham.saikrishna@gmail.com'
        }
    }
}
